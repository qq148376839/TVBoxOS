# TVBox Source Aggregator 配置

# 管理后台密码（必填）
ADMIN_TOKEN=changeme

# 服务端口
PORT=5678

# 定时聚合（Cron 表达式，UTC 时区）
# 默认 UTC 5:00 = 北京时间 13:00
CRON_SCHEDULE=0 5 * * *

# 刷新接口独立 Token（可选，留空则使用 ADMIN_TOKEN）
REFRESH_TOKEN=

# zbape.com 测速 API Key（可选，留空则跳过测速）
ZBAPE_API_KEY=

# 超时配置（毫秒）
SPEED_TIMEOUT_MS=5000
FETCH_TIMEOUT_MS=5000

# 数据目录（默认 ./data）
DATA_DIR=
